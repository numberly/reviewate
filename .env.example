# Reviewate Environment Configuration
# Copy this to .env and customize for your setup
#
# Quick Start (simple deployment):
#   1. Generate secrets: make generate-secrets
#   2. Set GitHub/GitLab OAuth credentials
#   3. Run: docker compose up -d
#   4. Access at http://localhost:3000
#
# For custom domain with HTTPS:
#   - Set DOMAIN to your domain
#   - Use your own reverse proxy (Traefik, Caddy, nginx, etc.)
#   - See nginx/ folder for example nginx config

# ==================== Environment ====================
NODE_ENV=production
CONFIG_ENV=local

# ==================== Ports (optional, defaults shown) ====================
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ==================== Domain (optional, for custom setup) ====================
# Leave as localhost for simple deployment
DOMAIN=localhost
COOKIE_DOMAIN=localhost

# ==================== Database ====================
POSTGRES_DB=reviewate
POSTGRES_USER=reviewate
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://reviewate:CHANGE_ME_STRONG_PASSWORD@postgres:5432/reviewate

# ==================== Redis Queue ====================
# Use Redis instead of Postgres queue (recommended for scale)
REDIS_URL=redis://redis:6379
REDIS_DB=0

# ==================== Security Secrets ====================
# Generate JWT secret: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# Generate encryption key: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_PYTHON

# ==================== Plugin Enablement ====================
# Enable/disable OAuth providers (default: true)
GITHUB_ENABLED=true
GITLAB_ENABLED=true
GOOGLE_ENABLED=true

# ==================== GitHub Integration ====================
# Homepage URL: https://your-domain.com
# Callback URL: https://your-domain.com/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# Create GitHub App: https://github.com/settings/apps
# Webhook URL: https://your-domain.com/webhooks/github/pr
# Permissions: Read repository contents, pull requests
# Events: Pull request
GITHUB_APP_ID=your-github-app-id
GITHUB_APP_NAME=reviewate
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
GITHUB_APP_PRIVATE_KEY_PATH=./certs/github-app-private-key.pem

# ==================== GitLab Integration ====================
# Create OAuth App: https://gitlab.com/-/profile/applications
# Redirect URI: https://your-domain.com/api/auth/callback/gitlab
GITLAB_CLIENT_ID=your-gitlab-client-id
GITLAB_CLIENT_SECRET=your-gitlab-client-secret
GITLAB_INSTANCE_URL=https://gitlab.com
GITLAB_WEBHOOK_SECRET=your-gitlab-webhook-secret

# ==================== Frontend URLs ====================
# For simple deployment (default):
FRONTEND_URL=http://localhost:3000
NUXT_PUBLIC_API_BASE_URL=http://localhost:8000
NUXT_PUBLIC_API_OPENAPI_URL=http://localhost:8000/openapi.json

# For custom domain with reverse proxy, use:
# FRONTEND_URL=https://your-domain.com
# NUXT_PUBLIC_API_BASE_URL=https://your-domain.com/api
# NUXT_PUBLIC_API_OPENAPI_URL=https://your-domain.com/api/openapi.json

# ==================== LLM Configuration ====================
# Option 1: Anthropic API key
ANTHROPIC_API_KEY=
# Option 2: Claude subscription (for container/headless use)
# CLAUDE_CODE_OAUTH_TOKEN=     # generate with: claude setup-token
# REVIEWATE_REVIEW_MODEL=sonnet  # optional, review tier (default: sonnet)
# REVIEWATE_UTILITY_MODEL=haiku # optional, utility tier (default: haiku)
# REVIEWATE_BASE_URL=           # optional, for proxy or custom endpoint

# ==================== Optional: Monitoring ====================
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id


# ==================== Optional: Google OAuth ====================
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
