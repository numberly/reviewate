{
  "name": "frontend",
  "description": "Reviewate dashboard — Nuxt 4 frontend for managing AI code reviews",
  "license": "AGPL-3.0",
  "author": "Reviewate Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/numberly/reviewate.git",
    "directory": "frontend"
  },
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,ts,vue,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,vue,json,md}\"",
    "typecheck": "nuxt typecheck",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@nuxt/eslint": "1.10.0",
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "4.1.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@pinia/nuxt": "^0.11.3",
    "@reviewate/api-types": "workspace:*",
    "@sentry/nuxt": "^10.43.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "driver.js": "^1.4.0",
    "eslint": "^9.39.4",
    "motion-v": "^1.10.3",
    "nuxt": "^4.4.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^3.23.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.4",
    "prettier": "^3.8.1",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.5"
  },
  "packageManager": "pnpm@10.21.0"
}
