{
  "name": "frontend",
  "description": "Reviewate dashboard — Nuxt 4 frontend for managing AI code reviews",
  "license": "AGPL-3.0",
  "author": "Reviewate Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/numberly/reviewate.git",
    "directory": "frontend"
  },
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,ts,vue,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,vue,json,md}\"",
    "typecheck": "nuxt typecheck",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@nuxt/eslint": "1.15.2",
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "4.6.0",
    "@nuxtjs/i18n": "10.2.4",
    "@pinia/nuxt": "0.11.3",
    "@reviewate/api-types": "workspace:*",
    "@sentry/nuxt": "10.46.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "driver.js": "1.4.0",
    "eslint": "10.1.0",
    "motion-v": "2.2.0",
    "nuxt": "4.4.2",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.2",
    "vue": "3.5.31",
    "vue-router": "5.0.4"
  },
  "devDependencies": {
    "@nuxt/test-utils": "4.0.0",
    "@playwright/test": "1.58.2",
    "@types/node": "25.5.0",
    "@vitejs/plugin-vue": "6.0.5",
    "@vue/test-utils": "2.4.6",
    "happy-dom": "20.8.9",
    "prettier": "3.8.1",
    "vitest": "4.1.2",
    "vue-tsc": "3.2.6"
  },
  "packageManager": "pnpm@10.21.0"
}
